# -------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# -------------------------------------------------------

# Email (SMTP) — works with Gmail, Outlook, or any SMTP server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=prachi@dietitianprachi.co.uk

# Upstash Redis (booking storage — required)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin dashboard password
ADMIN_PASSWORD=changeme123

# Google Calendar integration (OAuth 2.0)
# Follow the setup steps in SETUP.md to obtain these three values.
# The site works without them but slots will not reflect your real calendar.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
# Use "primary" or your full workspace email address
GOOGLE_CALENDAR_ID=primary
